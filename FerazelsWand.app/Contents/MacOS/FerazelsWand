#!/usr/bin/env bash
# Ferazel's Wand launcher — lives inside FerazelsWand.app/Contents/MacOS/.
# The .app can live anywhere inside the repo root and resolves sibling paths.
set -euo pipefail

MACOS_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "${MACOS_DIR}/../../.." && pwd)"
CONFIG="${REPO_ROOT}/config/qemu.conf.sh"

alert() {
    osascript -e "display dialog \"$1\" with title \"Ferazel's Wand\" buttons {\"OK\"} default button \"OK\" with icon stop" 2>/dev/null || true
}

if [[ ! -f "${CONFIG}" ]]; then
    alert "Configuration not found.\n\nMake sure FerazelsWand.app is inside the ferazels-wand-emulator folder."
    exit 1
fi

source "${CONFIG}"

if [[ ! -x "${QEMU_BIN:-}" ]]; then
    alert "QEMU not found.\n\nOpen Terminal in the repo folder and run:\n\n  make setup\n  make vendor\n\nThen double-click this app again."
    exit 1
fi

if [[ ! -f "${DISK_IMAGE}" ]]; then
    alert "Mac OS 9 disk image not found.\n\nOpen Terminal in the repo folder and run:\n\n  make create-disk\n  make install-os\n  make install-game\n  make apply-patches\n\nSee docs/setup-guide.md for the full walkthrough."
    exit 1
fi

# Check for an already-running QEMU session (write lock on the disk)
if pgrep -x qemu-system-ppc > /dev/null 2>&1; then
    alert "Ferazel's Wand is already running.\n\nClose the existing QEMU window first, then try again."
    exit 1
fi

QEMU_ERR=$(mktemp /tmp/fw_qemu_err_XXXXX)

"${QEMU_BIN}" \
    "${QEMU_BASE_FLAGS[@]}" \
    -device "ide-cd,bus=ide.1,unit=0,drive=cd0" \
    -drive  "id=cd0,file=${GAME_ISO},format=raw,if=none,media=cdrom,readonly=on,cache=unsafe" \
    -no-reboot 2>"${QEMU_ERR}"
QEMU_EXIT=$?

if [[ ${QEMU_EXIT} -ne 0 ]]; then
    ERR_MSG=$(cat "${QEMU_ERR}" 2>/dev/null | head -5)
    rm -f "${QEMU_ERR}"
    alert "QEMU exited with an error (code ${QEMU_EXIT}):\n\n${ERR_MSG}\n\nIf the disk is locked, make sure no other QEMU window is open."
    exit "${QEMU_EXIT}"
fi
rm -f "${QEMU_ERR}"
