# Disk images — large binary files, user-provided
# macos9.img is the raw Mac OS 9 disk (raw format required — see config/qemu.conf.sh quirk #1)
disks/*.img
disks/*.iso
disks/*.dmg

# Game and OS archives
*.sit
*.hqx
*.bin
*.rom

# Vendored QEMU binaries — populated by `make vendor`, not committed
vendor/qemu/

# macOS
.DS_Store
**/.DS_Store

# Xcode (future app/)
app/*.xcodeproj/xcuserdata/
app/DerivedData/
app/build/
*.xcworkspace/xcuserdata/
