# Disk images — large binary files, user-provided
disks/*.qcow2
disks/*.img
disks/*.iso
disks/*.dmg

# Game and OS archives
*.sit
*.hqx
*.bin
*.rom

# Vendored QEMU binaries — populated by `make vendor`, not committed
vendor/qemu/

# macOS
.DS_Store
**/.DS_Store

# Xcode (future app/)
app/*.xcodeproj/xcuserdata/
app/DerivedData/
app/build/
*.xcworkspace/xcuserdata/
